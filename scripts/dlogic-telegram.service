# 再構築用 systemd ユニット (2026-06-03 復元・新VPS用に再作成)
# 出典: CLAUDE.md (main.py = Telegram Bot エントリポイント, polling, /opt/dlogic/linebot 配下)
# 配置先: /etc/systemd/system/dlogic-telegram.service
# 用途: 管理者(jin)テスト用。本番は LINE Bot。
[Unit]
Description=Dlogic Telegram Bot (admin test, polling)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/dlogic/linebot
Environment=HOME=/root
ExecStart=/opt/dlogic/linebot/venv/bin/python main.py
Restart=always
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
